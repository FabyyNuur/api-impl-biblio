# SMTP (envoi des identifiants à la création d'un utilisateur par un bibliothécaire)
# Gmail : créer un "mot de passe d'application" (sans espaces) dans le compte Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=motdepasseapplication16caracteres
MAIL_FROM=Nuur Library <votre-email@gmail.com>

# URL du frontend (lien de connexion dans l'email)
FRONTEND_URL=http://localhost:3001

# Mot de passe temporaire assigné aux nouveaux comptes
DEFAULT_USER_PASSWORD=ChangeMe123
