# Copier ce fichier vers .env et adapter les valeurs :
#   cp .env.example .env

# ── Serveur ──────────────────────────────────────────────────────────────────
# Port d'écoute de l'API (défaut : 3000)
PORT=3000

# ── Authentification JWT ─────────────────────────────────────────────────────
# OBLIGATOIRE en production — secret long et aléatoire
JWT_SECRET=dev-secret-change-in-production
# Durée de validité du token (ex. 24h, 7d)
JWT_EXPIRES_IN=24h

# ── Compte bibliothécaire initial (seed au premier démarrage) ───────────────
# Créé automatiquement s'il n'existe pas encore de compte bibliothécaire
SEED_ADMIN_NOM=Admin
SEED_ADMIN_PRENOM=Bibliothèque
SEED_ADMIN_EMAIL=admin@biblio.com
SEED_ADMIN_PASSWORD=secret123

# ── Création d'utilisateurs par le bibliothécaire ───────────────────────────
# Mot de passe temporaire assigné aux nouveaux comptes (changé à la 1ère connexion)
DEFAULT_USER_PASSWORD=ChangeMe123

# ── SMTP (envoi des identifiants par email) ────────────────────────────────
# Sans SMTP configuré, l'email est simulé dans les logs (mode développement).
# Gmail : créer un "mot de passe d'application" (sans espaces) dans le compte Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=motdepasseapplication16caracteres
MAIL_FROM=Nuur Library <votre-email@gmail.com>

# ── Frontend ─────────────────────────────────────────────────────────────────
# URL du frontend (lien de connexion dans l'email)
FRONTEND_URL=http://localhost:3001
